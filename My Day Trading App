<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SHUBHAM · TRADING INTELLIGENCE</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
:root {
  --bg0: #04040a;
  --bg1: #080812;
  --bg2: #0c0c1a;
  --bg3: #10101f;
  --glass: rgba(12,12,26,0.7);
  --border: rgba(255,255,255,0.05);
  --border2: rgba(255,255,255,0.08);
  --border3: rgba(0,212,255,0.15);
  --cyan: #00d4ff;
  --cyan2: #00a8cc;
  --green: #00ff88;
  --green2: #00cc6a;
  --red: #ff3366;
  --red2: #cc2952;
  --purple: #7c3aed;
  --gold: #fbbf24;
  --text: #c8d6e5;
  --dim: #4a5568;
  --dimmer: #2d3748;
  --white: #f0f4f8;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg0);
  color: var(--text);
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ── BACKGROUND GRID ── */
body::before {
  content: '';
  position: fixed;
  inset: 0;
  background-image:
    linear-gradient(rgba(0,212,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,212,255,0.03) 1px, transparent 1px);
  background-size: 48px 48px;
  pointer-events: none;
  z-index: 0;
}
body::after {
  content: '';
  position: fixed;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(ellipse at 20% 20%, rgba(124,58,237,0.06) 0%, transparent 50%),
              radial-gradient(ellipse at 80% 80%, rgba(0,212,255,0.05) 0%, transparent 50%);
  pointer-events: none;
  z-index: 0;
}

/* ── CONFIG OVERLAY ── */
#configOverlay {
  position: fixed; inset: 0;
  background: rgba(4,4,10,0.97);
  display: flex; align-items: center; justify-content: center;
  z-index: 9999;
  backdrop-filter: blur(10px);
}
.cfg-wrap {
  width: 460px;
  background: var(--bg2);
  border: 1px solid var(--border3);
  border-radius: 16px;
  padding: 40px;
  position: relative;
  overflow: hidden;
}
.cfg-wrap::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--cyan), transparent);
}
.cfg-logo {
  display: flex; align-items: center; gap: 12px; margin-bottom: 28px;
}
.cfg-icon {
  width: 48px; height: 48px; border-radius: 12px;
  background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(124,58,237,0.2));
  border: 1px solid var(--border3);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px;
}
.cfg-title { font-size: 20px; font-weight: 800; color: var(--white); }
.cfg-title span { color: var(--cyan); }
.cfg-sub { font-size: 12px; color: var(--dim); margin-top: 2px; }
.cfg-label {
  font-size: 10px; font-weight: 600; letter-spacing: 1.5px;
  color: var(--dim); text-transform: uppercase; margin-bottom: 6px;
}
.cfg-input {
  width: 100%;
  background: var(--bg3);
  border: 1px solid var(--border2);
  border-radius: 8px;
  color: var(--white);
  font-family: 'JetBrains Mono', monospace;
  font-size: 12px;
  padding: 11px 14px;
  margin-bottom: 16px;
  outline: none;
  transition: border-color 0.2s;
}
.cfg-input:focus { border-color: var(--cyan); box-shadow: 0 0 0 3px rgba(0,212,255,0.1); }
.cfg-btn {
  width: 100%;
  padding: 13px;
  background: linear-gradient(135deg, var(--cyan2), var(--purple));
  color: #fff;
  font-family: 'Inter', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 1px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.1s;
}
.cfg-btn:hover { opacity: 0.9; transform: translateY(-1px); }
.cfg-btn:active { transform: translateY(0); }
.cfg-err { color: var(--red); font-size: 11px; margin-top: 10px; display: none; font-family: 'JetBrains Mono', monospace; }

/* ── TICKER TAPE ── */
.ticker-wrap {
  position: relative;
  background: var(--bg1);
  border-bottom: 1px solid var(--border);
  height: 32px;
  overflow: hidden;
  z-index: 10;
}
.ticker-inner {
  display: flex;
  align-items: center;
  height: 100%;
  white-space: nowrap;
  animation: ticker 30s linear infinite;
}
.ticker-item {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 0 24px;
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px;
  font-weight: 500;
  color: var(--dim);
  border-right: 1px solid var(--border);
}
.ticker-item .sym { color: var(--text); font-weight: 600; }
.ticker-item .up { color: var(--green); }
.ticker-item .dn { color: var(--red); }
@keyframes ticker {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* ── LOADING BAR ── */
#loadingBar {
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--cyan), var(--purple), var(--cyan), transparent);
  background-size: 300% 100%;
  animation: loadAnim 1.2s ease infinite;
  display: none;
  position: fixed; top: 0; left: 0; right: 0; z-index: 9998;
}
@keyframes loadAnim { 0%{background-position:100% 0} 100%{background-position:-100% 0} }

/* ── HEADER ── */
.hdr {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 24px;
  height: 64px;
  background: rgba(8,8,18,0.9);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(20px);
  position: sticky; top: 0; z-index: 100;
}
.hdr-left { display: flex; align-items: center; gap: 14px; }
.hdr-logo {
  width: 40px; height: 40px; border-radius: 10px;
  background: linear-gradient(135deg, rgba(0,212,255,0.25), rgba(124,58,237,0.25));
  border: 1px solid rgba(0,212,255,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  box-shadow: 0 0 20px rgba(0,212,255,0.15);
}
.hdr-info {}
.hdr-name {
  font-size: 15px; font-weight: 800; color: var(--white);
  letter-spacing: 0.5px;
}
.hdr-name span { color: var(--cyan); }
.hdr-sub {
  font-size: 9px; font-weight: 500; letter-spacing: 2px;
  color: var(--dim); text-transform: uppercase; margin-top: 1px;
}
.hdr-center { display: flex; align-items: center; gap: 8px; }
.hdr-nav {
  display: flex; gap: 2px;
  background: var(--bg2);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 3px;
}
.hdr-nav-item {
  padding: 5px 14px; border-radius: 6px;
  font-size: 11px; font-weight: 600; color: var(--dim);
  cursor: pointer; transition: all 0.2s;
}
.hdr-nav-item.active { background: var(--border2); color: var(--white); }
.hdr-nav-item:hover { color: var(--text); }
.hdr-right { display: flex; align-items: center; gap: 16px; }
.hdr-pv {}
.hdr-pv-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 22px; font-weight: 700;
  color: var(--white);
  text-shadow: 0 0 30px rgba(0,255,136,0.3);
  line-height: 1;
}
.hdr-pv-lbl { font-size: 9px; color: var(--dim); letter-spacing: 1.5px; text-align: right; margin-top: 2px; }
.hdr-pv-chg { font-size: 11px; font-weight: 600; text-align: right; }
.hdr-pv-chg.up { color: var(--green); }
.hdr-pv-chg.dn { color: var(--red); }
.hdr-status { display: flex; flex-direction: column; align-items: flex-end; gap: 5px; }
.live-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(0,255,136,0.1);
  border: 1px solid rgba(0,255,136,0.25);
  border-radius: 20px;
  padding: 3px 10px;
  font-size: 10px; font-weight: 700; color: var(--green);
  letter-spacing: 1px;
}
.live-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--green);
  box-shadow: 0 0 6px var(--green);
  animation: livepulse 2s ease infinite;
}
@keyframes livepulse {
  0%,100%{ opacity:1; box-shadow: 0 0 6px var(--green); }
  50%{ opacity:0.5; box-shadow: 0 0 12px var(--green); }
}
.hdr-clock {
  font-family: 'JetBrains Mono', monospace;
  font-size: 11px; color: var(--dim);
}
.refresh-btn {
  background: rgba(0,212,255,0.08);
  border: 1px solid rgba(0,212,255,0.2);
  border-radius: 6px;
  color: var(--cyan);
  font-family: 'Inter', sans-serif;
  font-size: 11px; font-weight: 600;
  padding: 6px 12px;
  cursor: pointer;
  transition: all 0.2s;
}
.refresh-btn:hover { background: rgba(0,212,255,0.15); }

/* ── MAIN LAYOUT ── */
.main { position: relative; z-index: 1; padding: 20px 20px 40px; }

/* ── SECTION LABEL ── */
.sec-label {
  font-size: 10px; font-weight: 600; letter-spacing: 2px;
  color: var(--dim); text-transform: uppercase;
  display: flex; align-items: center; gap: 8px;
  margin-bottom: 12px; margin-top: 24px;
}
.sec-label::before {
  content: '';
  width: 3px; height: 12px; border-radius: 2px;
  background: var(--cyan);
  box-shadow: 0 0 8px var(--cyan);
}
.sec-label span { color: var(--dimmer); font-weight: 400; }

/* ── CARD ── */
.card {
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px;
  position: relative;
  overflow: hidden;
  backdrop-filter: blur(20px);
  transition: border-color 0.2s;
}
.card:hover { border-color: var(--border2); }
.card-shine {
  position: absolute;
  top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.07) 50%, transparent 100%);
}
.card-lbl {
  font-size: 9px; font-weight: 600; letter-spacing: 2px;
  color: var(--dim); text-transform: uppercase;
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 14px;
}
.card-lbl-badge {
  font-size: 9px; color: var(--dimmer); font-weight: 400;
  background: var(--bg3); border: 1px solid var(--border);
  border-radius: 4px; padding: 2px 6px;
}

/* ── GRID LAYOUTS ── */
.g4 { display: grid; grid-template-columns: repeat(4,1fr); gap: 14px; }
.g3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; }
.g2 { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.g21 { display: grid; grid-template-columns: 2fr 1fr; gap: 14px; }
.g12 { display: grid; grid-template-columns: 1fr 2fr; gap: 14px; }
.full { grid-column: 1/-1; }

/* ── STAT CARDS ── */
.stat-card {
  background: var(--glass);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 18px;
  backdrop-filter: blur(20px);
  position: relative;
  overflow: hidden;
}
.stat-card-glow {
  position: absolute;
  bottom: 0; right: 0;
  width: 80px; height: 80px;
  border-radius: 50%;
  opacity: 0.12;
  filter: blur(20px);
}
.stat-lbl {
  font-size: 9px; font-weight: 600; letter-spacing: 2px;
  color: var(--dim); text-transform: uppercase; margin-bottom: 10px;
}
.stat-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 28px; font-weight: 700;
  line-height: 1;
  color: var(--white);
}
.stat-val.cyan { color: var(--cyan); text-shadow: 0 0 20px rgba(0,212,255,0.4); }
.stat-val.green { color: var(--green); text-shadow: 0 0 20px rgba(0,255,136,0.4); }
.stat-val.red { color: var(--red); text-shadow: 0 0 20px rgba(255,51,102,0.4); }
.stat-val.gold { color: var(--gold); text-shadow: 0 0 20px rgba(251,191,36,0.4); }
.stat-sub { font-size: 11px; color: var(--dim); margin-top: 6px; }
.stat-delta {
  font-size: 11px; font-weight: 600;
  margin-top: 4px;
}
.stat-delta.up { color: var(--green); }
.stat-delta.dn { color: var(--red); }

/* ── ACCOUNT OVERVIEW ── */
.equity-big {
  font-family: 'JetBrains Mono', monospace;
  font-size: 48px; font-weight: 700;
  color: var(--white);
  letter-spacing: -2px;
  line-height: 1;
  text-shadow: 0 0 40px rgba(0,255,136,0.2);
}
.equity-sub { font-size: 12px; color: var(--dim); margin-top: 8px; }
.equity-sub b { color: var(--text); }
.acct-pills { display: flex; gap: 8px; margin-top: 16px; flex-wrap: wrap; }
.acct-pill {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 8px 14px;
  flex: 1;
}
.acct-pill-lbl { font-size: 8px; color: var(--dim); letter-spacing: 1.5px; font-weight: 600; margin-bottom: 4px; }
.acct-pill-val {
  font-family: 'JetBrains Mono', monospace;
  font-size: 14px; font-weight: 600; color: var(--white);
}

/* ── POSITION CARDS ── */
.pos-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
.pos-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s, border-color 0.2s;
}
.pos-card:hover { transform: translateY(-2px); border-color: var(--border2); }
.pos-card-top { display: flex; justify-content: space-between; align-items: flex-start; }
.pos-sym {
  font-size: 16px; font-weight: 800; color: var(--white);
  letter-spacing: 0.5px;
}
.pos-side {
  font-size: 9px; font-weight: 700; letter-spacing: 1px;
  padding: 2px 7px; border-radius: 4px;
}
.pos-side.long { background: rgba(0,255,136,0.1); color: var(--green); border: 1px solid rgba(0,255,136,0.2); }
.pos-side.short { background: rgba(255,51,102,0.1); color: var(--red); border: 1px solid rgba(255,51,102,0.2); }
.pos-qty { font-size: 11px; color: var(--dim); margin-top: 3px; }
.pos-pnl {
  font-family: 'JetBrains Mono', monospace;
  font-size: 22px; font-weight: 700;
  margin-top: 10px; line-height: 1;
}
.pos-pnl.up { color: var(--green); text-shadow: 0 0 15px rgba(0,255,136,0.3); }
.pos-pnl.dn { color: var(--red); text-shadow: 0 0 15px rgba(255,51,102,0.3); }
.pos-pct { font-size: 12px; font-weight: 600; margin-top: 3px; }
.pos-pct.up { color: var(--green); }
.pos-pct.dn { color: var(--red); }
.pos-prices { font-size: 10px; color: var(--dim); margin-top: 8px; }
.pos-prices b { color: var(--text); }
.pos-bar { height: 3px; background: var(--border); border-radius: 2px; margin-top: 10px; overflow: hidden; }
.pos-bar-fill { height: 100%; border-radius: 2px; transition: width 1s ease; }
.pos-glow {
  position: absolute; bottom: -20px; right: -20px;
  width: 80px; height: 80px; border-radius: 50%;
  opacity: 0.08; filter: blur(15px);
}

/* ── STRATEGY SIGNALS ── */
.signal-grid { display: grid; grid-template-columns: repeat(5,1fr); gap: 8px; }
.signal-card {
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 12px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.signal-sym { font-size: 13px; font-weight: 800; color: var(--white); }
.signal-price { font-family: 'JetBrains Mono', monospace; font-size: 11px; color: var(--dim); margin-top: 2px; }
.signal-badge {
  display: inline-block;
  margin-top: 8px;
  padding: 4px 12px;
  border-radius: 20px;
  font-size: 10px; font-weight: 800;
  letter-spacing: 1px;
}
.signal-badge.buy { background: rgba(0,255,136,0.1); color: var(--green); border: 1px solid rgba(0,255,136,0.3); }
.signal-badge.sell { background: rgba(255,51,102,0.1); color: var(--red); border: 1px solid rgba(255,51,102,0.3); }
.signal-badge.hold { background: rgba(74,85,104,0.2); color: var(--dim); border: 1px solid var(--border); }
.signal-bars { display: flex; gap: 2px; justify-content: center; margin-top: 8px; }
.signal-bar { width: 4px; border-radius: 2px; background: var(--dimmer); }
.signal-bar.active { background: var(--cyan); }

/* ── ORDERS TABLE ── */
.orders-table { width: 100%; border-collapse: collapse; }
.orders-table th {
  font-size: 9px; font-weight: 600; letter-spacing: 1.5px;
  color: var(--dim); text-transform: uppercase;
  padding: 8px 10px;
  border-bottom: 1px solid var(--border);
  text-align: left;
}
.orders-table td {
  padding: 9px 10px;
  border-bottom: 1px solid rgba(255,255,255,0.03);
  font-size: 12px;
  color: var(--text);
}
.orders-table tr:hover td { background: rgba(255,255,255,0.02); }
.orders-table tr:last-child td { border-bottom: none; }
.side-buy { color: var(--green); font-weight: 700; font-size: 10px; letter-spacing: 1px; }
.side-sell { color: var(--red); font-weight: 700; font-size: 10px; letter-spacing: 1px; }
.orders-sym { font-weight: 700; color: var(--white); font-size: 13px; }
.orders-price { font-family: 'JetBrains Mono', monospace; font-size: 11px; }
.orders-time { font-size: 10px; color: var(--dim); }

/* ── TRADINGVIEW ── */
.tv-tabs {
  display: flex; gap: 4px; margin-bottom: 12px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 4px;
  width: fit-content;
}
.tv-tab {
  padding: 6px 16px;
  border-radius: 6px;
  font-size: 11px; font-weight: 600;
  color: var(--dim);
  cursor: pointer;
  transition: all 0.2s;
}
.tv-tab.active { background: rgba(0,212,255,0.12); color: var(--cyan); border: 1px solid rgba(0,212,255,0.2); }
.tv-tab:hover:not(.active) { color: var(--text); }
.tv-frame { display: none; border-radius: 8px; overflow: hidden; }
.tv-frame.active { display: block; }

/* ── METRICS ── */
.mrow {
  display: flex; justify-content: space-between; align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.mrow:last-child { border-bottom: none; }
.ml { font-size: 11px; color: var(--dim); }
.mv { font-family: 'JetBrains Mono', monospace; font-size: 12px; font-weight: 600; color: var(--text); }
.mv.g { color: var(--green); }
.mv.r { color: var(--red); }
.mv.c { color: var(--cyan); }

/* ── CONFIDENCE BAR ── */
.conf-wrap { margin-top: 16px; }
.conf-label { display: flex; justify-content: space-between; margin-bottom: 6px; }
.conf-text { font-size: 9px; color: var(--dim); letter-spacing: 1.5px; font-weight: 600; }
.conf-pct {
  font-family: 'JetBrains Mono', monospace;
  font-size: 22px; font-weight: 700; color: var(--green);
  text-shadow: 0 0 15px rgba(0,255,136,0.4);
}
.conf-bar { height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
.conf-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--green2), var(--green));
  border-radius: 2px;
  box-shadow: 0 0 8px rgba(0,255,136,0.4);
  transition: width 1.5s cubic-bezier(0.4,0,0.2,1);
}

/* ── GALTON CANVAS ── */
#galtonCanvas { display: block; border-radius: 8px; }

/* ── STRATEGY LEGEND ── */
.strategy-list { display: flex; flex-direction: column; gap: 6px; margin-top: 12px; }
.strategy-item {
  display: flex; align-items: center; gap: 8px;
  padding: 8px 10px;
  background: var(--bg3);
  border: 1px solid var(--border);
  border-radius: 8px;
}
.strategy-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.strategy-name { font-size: 11px; font-weight: 600; color: var(--text); flex: 1; }
.strategy-rule { font-size: 9px; color: var(--dim); }

/* ── SCROLLBAR ── */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: var(--bg1); }
::-webkit-scrollbar-thumb { background: var(--dimmer); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--dim); }

/* ── EMPTY STATE ── */
.empty { padding: 30px; text-align: center; color: var(--dimmer); font-size: 12px; }

/* ── DIVIDER ── */
.divider { height: 1px; background: var(--border); margin: 4px 0; }

/* ── CHART WRAPPER ── */
.chart-wrap { position: relative; }

/* ── PULSE RING ON LIVE DOT ── */
@keyframes ring {
  0% { transform: scale(1); opacity: 0.6; }
  100% { transform: scale(2.5); opacity: 0; }
}
</style>
</head>
<body>

<!-- ── CONFIG OVERLAY ── -->
<div id="configOverlay">
  <div class="cfg-wrap">
