// ─── ANIMATED NUMBER ─────────────────────────────────────────
function animNum(el, target, fmt, ms) {
  const start = performance.now();
  (function step(now) {
    const t = Math.min(1,(now-start)/ms);
    const e = 1-Math.pow(1-t,4);
    el.textContent = fmt(target*e);
    if (t<1) requestAnimationFrame(step);
  })(start);
}

