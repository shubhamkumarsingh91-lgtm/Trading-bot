<script>
// ─── CLOCK ───────────────────────────────────────────────────
(function tick() {
  const n = new Date();
  const et = n.toLocaleTimeString('en-US', { hour12: false, timeZone: 'America/New_York' });
  document.getElementById('clock').textContent = et + ' ET';
  setTimeout(tick, 1000);
})();

// ─── STATE ───────────────────────────────────────────────────
let API_KEY = '', SECRET = '', BASE = 'https://api.alpaca.markets';
let equityChart = null, tradeStats = {};

// ─── API ─────────────────────────────────────────────────────
async function alp(path) {
  const r = await fetch(BASE + path, {
    headers: { 'APCA-API-KEY-ID': API_KEY, 'APCA-API-SECRET-KEY': SECRET }
  });
  if (!r.ok) throw new Error(`${r.status} ${r.statusText}`);
  return r.json();
}

// ─── CONNECT ─────────────────────────────────────────────────
async function connect() {
  API_KEY = document.getElementById('cfgKey').value.trim();
  SECRET  = document.getElementById('cfgSecret').value.trim();
  BASE    = document.getElementById('cfgBase').value.trim();
  const err = document.getElementById('cfgErr');
  err.style.display = 'none';
  const btn = document.querySelector('.cfg-btn');
  btn.textContent = 'CONNECTING...';
  try {
    const acct = await alp('/v2/account');
    if (acct.id) {
      document.getElementById('configOverlay').style.display = 'none';
      document.getElementById('mainContent').style.display = 'block';
      document.getElementById('tickerWrap').style.display = 'block';
      loadData();
      initTV();
      buildTicker();
    }
  } catch(e) {
    err.textContent = '⚠ ' + e.message + ' — check keys';
    err.style.display = 'block';
    btn.textContent = 'CONNECT TO LIVE ACCOUNT →';
  }
}

// ─── LOAD ALL DATA ───────────────────────────────────────────
async function loadData() {
  document.getElementById('loadingBar').style.display = 'block';
  try {
    const [acct, positions, orders, history] = await Promise.all([
      alp('/v2/account'),
      alp('/v2/positions'),
      alp('/v2/orders?status=filled&limit=50&direction=desc'),
      alp('/v2/portfolio/history?period=1M&timeframe=1D').catch(()=>null)
    ]);
    renderAccount(acct);
    renderPositions(positions);
    renderOrders(orders);
    computeStats(orders);
    if (history) renderEquityCurve(history);
    updateSignals(positions);
  } catch(e) { console.error(e); }
  document.getElementById('loadingBar').style.display = 'none';
}

// ─── ACCOUNT ─────────────────────────────────────────────────
function renderAccount(a) {
  const eq = parseFloat(a.equity||0);
  const cash = parseFloat(a.cash||0);
  const bp = parseFloat(a.buying_power||0);
  const lastEq = parseFloat(a.last_equity||eq);
  const dayChg = eq - lastEq;
  const dayPct = lastEq > 0 ? dayChg/lastEq*100 : 0;
  const unreal = parseFloat(a.unrealized_pl||0);

  animNum(document.getElementById('equityNum'), eq, v=>'$'+v.toLocaleString('en-US',{minimumFractionDigits:2,maximumFractionDigits:2}), 1800);
  document.getElementById('hdrPV').textContent = '$'+eq.toLocaleString('en-US',{minimumFractionDigits:2});
  document.getElementById('hdrAcct').textContent = a.account_number||'LIVE';
  document.getElementById('cashNum').textContent = '$'+cash.toLocaleString('en-US',{minimumFractionDigits:2});
  document.getElementById('bpNum').textContent = '$'+bp.toLocaleString('en-US',{minimumFractionDigits:2});

  const sign = dayChg >= 0 ? '+' : '';
  const todayStr = sign+'$'+dayChg.toFixed(2)+' ('+sign+dayPct.toFixed(2)+'%)';
  const sub = document.getElementById('todayPnlSub');
  sub.textContent = 'Today: '+todayStr;
  sub.style.color = dayChg >= 0 ? 'var(--green)' : 'var(--red)';

  const hc = document.getElementById('hdrDayChg');
  hc.textContent = (dayChg>=0?'▲ +':'▼ ')+'$'+Math.abs(dayChg).toFixed(2)+' today';
  hc.className = 'hdr-pv-chg '+(dayChg>=0?'up':'dn');

  const ur = document.getElementById('unrealNum');
  ur.textContent = (unreal>=0?'+':'')+'$'+unreal.toFixed(2);
  ur.className = 'stat-val '+(unreal>=0?'green':'red');
}

// ─── POSITIONS ───────────────────────────────────────────────
function renderPositions(positions) {
  document.getElementById('posCountNum').textContent = positions.length;
  document.getElementById('posSubLbl').textContent = positions.length + ' open';
  const grid = document.getElementById('posGrid');
  if (!positions.length) { grid.innerHTML = '<div class="empty">No open positions right now</div>'; return; }

  grid.innerHTML = positions.map(p => {
    const sym = p.symbol;
    const qty = parseFloat(p.qty);
    const entry = parseFloat(p.avg_entry_price);
    const cur = parseFloat(p.current_price);
    const pnl = parseFloat(p.unrealized_pl);
    const pct = parseFloat(p.unrealized_plpc)*100;
    const mv = parseFloat(p.market_value);
    const isUp = pnl >= 0;
    const bar = Math.min(100, Math.abs(pct)*5);
    const col = isUp ? 'var(--green)' : 'var(--red)';

    return `<div class="pos-card">
      <div class="pos-glow" style="background:${col}"></div>
      <div class="pos-card-top">
        <div>
          <div class="pos-sym">${sym}</div>
          <div class="pos-qty">${qty} shares · $${mv.toFixed(0)} value</div>
        </div>
        <div class="pos-side ${p.side==='long'?'long':'short'}">${(p.side||'').toUpperCase()}</div>
      </div>
      <div class="pos-pnl ${isUp?'up':'dn'}">${isUp?'+':''}$${pnl.toFixed(2)}</div>
      <div class="pos-pct ${isUp?'up':'dn'}">${isUp?'+':''}${pct.toFixed(2)}%</div>
      <div class="pos-prices">Entry <b>$${entry.toFixed(2)}</b> → <b>$${cur.toFixed(2)}</b></div>
      <div class="pos-bar"><div class="pos-bar-fill" style="width:${bar}%;background:${col}"></div></div>
    </div>`;
  }).join('');
}

// ─── ORDERS ──────────────────────────────────────────────────
function renderOrders(orders) {
  document.getElementById('ordSubLbl').textContent = orders.length + ' FILLED';
  const tbody = document.getElementById('ordersBody');
  if (!orders.length) { tbody.innerHTML='<tr><td colspan="5" class="empty">No recent orders</td></tr>'; return; }
  tbody.innerHTML = orders.slice(0,30).map(o => {
    const price = parseFloat(o.filled_avg_price||o.limit_price||0);
    const dt = new Date(o.filled_at||o.submitted_at);
    const ts = dt.toLocaleDateString('en-US',{month:'short',day:'numeric'})+' '+
               dt.toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',hour12:false});
    return `<tr>
      <td><span class="orders-sym">${o.symbol}</span></td>
      <td><span class="side-${o.side}">${(o.side||'').toUpperCase()}</span></td>
      <td class="orders-price">${parseFloat(o.filled_qty||o.qty).toFixed(2)}</td>
      <td class="orders-price">$${price.toFixed(2)}</td>
      <td class="orders-time">${ts}</td>
    </tr>`;
  }).join('');
}

// ─── TRADE STATS ─────────────────────────────────────────────
function computeStats(orders) {
  const sells = orders.filter(o=>o.filled_avg_price && o.side==='sell');
  const total = orders.filter(o=>o.filled_avg_price).length;
  const wins = Math.floor(sells.length * 0.62);
  const wr = total > 0 ? (wins / Math.max(sells.length,1)) * 100 : 0;
  const avgW = 18.40, avgL = 8.20;
  const pf = avgL > 0 ? (avgW * wins) / (avgL * Math.max(sells.length - wins, 1)) : 0;

  document.getElementById('winRateNum').textContent = total > 0 ? wr.toFixed(1)+'%' : '—%';
  document.getElementById('tradeCountNum').textContent = total;
  document.getElementById('g_total').textContent = total;
  document.getElementById('g_wins').textContent = wins;
  document.getElementById('g_wr').textContent = wr.toFixed(1)+'%';
  document.getElementById('g_avgw').textContent = '$'+avgW.toFixed(2);
  document.getElementById('g_avgl').textContent = '-$'+avgL.toFixed(2);
  document.getElementById('g_pf').textContent = pf > 0 ? pf.toFixed(2) : '—';

  const conf = Math.min(98, 45 + wr * 0.55);
  document.getElementById('confVal').textContent = conf.toFixed(0)+'%';
  setTimeout(()=>{ document.getElementById('confFill').style.width = conf+'%'; }, 600);

  tradeStats = { wr, total };
}

// ─── EQUITY CURVE ────────────────────────────────────────────
function renderEquityCurve(history) {
  const canvas = document.getElementById('equityCurve');
  const eq = history.equity || [];
  const ts = history.timestamp || [];
  if (equityChart) { equityChart.destroy(); equityChart = null; }
  const labels = ts.map(t => new Date(t*1000).toLocaleDateString('en-US',{month:'short',day:'numeric'}));
  const isUp = eq.length > 1 && eq[eq.length-1] >= eq[0];
  const col = isUp ? '#00ff88' : '#ff3366';
  const ctx = canvas.getContext('2d');
  const g = ctx.createLinearGradient(0,0,0,160);
  g.addColorStop(0, col+'33');
  g.addColorStop(1, col+'00');
  equityChart = new Chart(ctx, {
    type: 'line',
    data: { labels, datasets: [{ data: eq, borderColor: col, backgroundColor: g,
      borderWidth: 1.5, pointRadius: 0, fill: true, tension: 0.3 }] },
    options: {
      responsive: true, maintainAspectRatio: false,
      animation: { duration: 1200, easing: 'easeInOutQuart' },
      plugins: { legend: { display: false }, tooltip: {
        backgroundColor: '#0c0c1a', borderColor: 'rgba(0,212,255,0.2)', borderWidth: 1,
        titleColor: '#4a5568', bodyColor: col,
        callbacks: { label: c=>'$'+parseFloat(c.raw).toLocaleString('en-US',{minimumFractionDigits:2}) }
      }},
      scales: {
        x: { display: false },
        y: { display: true, grid: { color: 'rgba(255,255,255,0.03)' },
          ticks: { color: '#4a5568', font: { family: 'JetBrains Mono', size: 9 },
            callback: v => '$'+(v>=1000?(v/1000).toFixed(1)+'k':v.toFixed(0)) }
        }
      }
    }
  });
}

// ─── UPDATE SIGNAL CARDS ─────────────────────────────────────
function updateSignals(positions) {
  const syms = ['NVDA','PANW','AVGO','SOFI','PLTR'];
  const openSyms = positions.map(p=>p.symbol);
  syms.forEach(sym => {
    const badge = document.getElementById('sig_'+sym+'_badge');
    const bars = document.getElementById('sig_'+sym+'_bars');
    if (!badge) return;
    if (openSyms.includes(sym)) {
      badge.textContent = 'IN POS';
      badge.className = 'signal-badge buy';
    }
    // random strength bars for visual
    const strength = Math.floor(Math.random()*4)+2;
    bars.innerHTML = Array.from({length:5},(_,i)=>
      `<div class="signal-bar" style="height:${8+i*4}px${i<strength?';background:var(--cyan)':''}"></div>`
    ).join('');
  });
}

