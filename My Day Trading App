// ─── GALTON BOARD ────────────────────────────────────────────
(function() {
  const canvas = document.getElementById('galtonCanvas');
  const ctx = canvas.getContext('2d');
  const ROWS = 8;
  const bins = new Array(ROWS+1).fill(0);
  const balls = [];

  function pegPos(row, col, w, h) {
    const top=28, bot=50, gy=(h-top-bot)/ROWS, gx=w/(ROWS+2);
    return { x: w/2+(col-row/2)*gx, y: top+row*gy };
  }

  class Ball {
    constructor(w,h) {
      this.w=w; this.h=h;
      const wr = (tradeStats.wr||62)/100;
      this.turns = Array.from({length:ROWS},()=>Math.random()<wr?1:0);
      this.finalBin = this.turns.reduce((a,b)=>a+b,0);
      this.row=0; this.col=0; this.t=0; this.speed=0.035+Math.random()*0.02;
      this.x=w/2; this.y=20;
      const p0=pegPos(0,0,w,h);
      this.sx=this.x; this.sy=this.y; this.tx=p0.x; this.ty=p0.y;
      this.done=false; this.alpha=1;
      this.isWin = this.finalBin >= ROWS*0.4;
      this.color = this.isWin ? '#00ff88' : '#ff3366';
    }
    update() {
      if (this.done) { this.alpha -= 0.01; return; }
      this.t += this.speed;
      if (this.t >= 1) {
        this.t=0; this.x=this.tx; this.y=this.ty; this.row++;
        if (this.row>ROWS) { bins[this.finalBin]++; this.done=true; return; }
        this.col += this.turns[this.row-1];
        const np=pegPos(this.row,this.col,this.w,this.h);
        this.sx=this.x; this.sy=this.y; this.tx=np.x; this.ty=np.y;
      }
      const ease=t=>t<0.5?2*t*t:-1+(4-2*t)*t;
      const et=ease(this.t);
      this.x=this.sx+(this.tx-this.sx)*et;
      this.y=this.sy+(this.ty-this.sy)*et-Math.sin(this.t*Math.PI)*6;
    }
    draw() {
      if (this.alpha<=0) return;
      ctx.save();
      ctx.globalAlpha=Math.max(0,this.alpha);
      ctx.shadowColor=this.color; ctx.shadowBlur=12;
      ctx.beginPath(); ctx.arc(this.x,this.y,4,0,Math.PI*2);
      ctx.fillStyle=this.color; ctx.fill();
      ctx.restore();
    }
  }

  function frame() {
    canvas.width=canvas.offsetWidth||280; canvas.height=260;
    const w=canvas.width, h=canvas.height;
    ctx.clearRect(0,0,w,h);

    // pegs
    for (let r=0;r<=ROWS;r++) {
      for (let c=0;c<=r;c++) {
        const p=pegPos(r,c,w,h);
        ctx.beginPath(); ctx.arc(p.x,p.y,2.5,0,Math.PI*2);
        ctx.fillStyle='rgba(0,212,255,0.2)'; ctx.fill();
        if (r<ROWS) {
          const l=pegPos(r+1,c,w,h), rr=pegPos(r+1,c+1,w,h);
          ctx.strokeStyle='rgba(255,255,255,0.04)'; ctx.lineWidth=0.5;
          [l,rr].forEach(pp=>{ ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(pp.x,pp.y); ctx.stroke(); });
        }
      }
    }

    // bins
    const maxBin=Math.max(...bins,1);
    const gx=w/(ROWS+2), binY=h-8, maxH=42;
    for(let i=0;i<=ROWS;i++){
      const pp=pegPos(ROWS,i,w,h), bw=gx*0.8, bx=pp.x-bw/2;
      const bh=(bins[i]/maxBin)*maxH, isG=i>=ROWS*0.4;
      const c=isG?'0,255,136':'255,51,102';
      ctx.fillStyle=`rgba(${c},0.08)`; ctx.fillRect(bx,binY-maxH,bw,maxH);
      ctx.fillStyle=`rgba(${c},0.25)`; ctx.fillRect(bx,binY-bh,bw,bh);
    }

    ctx.font='9px JetBrains Mono'; ctx.fillStyle='rgba(255,51,102,0.6)';
    ctx.textAlign='left'; ctx.fillText('LOSS', 6, h-2);
    ctx.fillStyle='rgba(0,255,136,0.6)'; ctx.textAlign='right';
    ctx.fillText('WIN', w-6, h-2);

    balls.forEach(b=>{b.update();b.draw();});
    for(let i=balls.length-1;i>=0;i--) if(balls[i].alpha<=0) balls.splice(i,1);
    if(balls.length<6 && Math.random()<0.05) balls.push(new Ball(w,h));

    requestAnimationFrame(frame);
  }
  frame();
})();
</script>
